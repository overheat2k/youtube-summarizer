{
  "manifest_version": 3,
  "name": "YouTube Summarizer",
  "version": "1.1.0",
  "description": "一键总结 YouTube 视频 — 本地字幕获取 + AI 总结",
  "author": "Alex Xie",

  "permissions": ["storage"],

  "host_permissions": [
    "http://127.0.0.1:8643/*",
    "http://localhost:8643/*",
    "http://127.0.0.1:8642/*",
    "http://localhost:8642/*",
    "https://api.openai.com/*",
    "https://openrouter.ai/*"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "YouTube Summarizer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
